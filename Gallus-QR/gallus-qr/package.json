{
	"name": "gallus-qr",
	"version": "2.0.0",
	"description": "Dev tooling for the Gallus QR WordPress plugin (the shipped plugin has no build step).",
	"private": true,
	"devDependencies": {
		"@wordpress/env": "^10.0.0"
	},
	"scripts": {
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"env:destroy": "wp-env destroy",
		"test:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/gallus-qr ./vendor/bin/phpunit"
	}
}
